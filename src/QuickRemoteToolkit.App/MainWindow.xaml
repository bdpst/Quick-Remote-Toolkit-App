<Window x:Class="QuickRemoteToolkit.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quick Remote Toolkit"
        Width="1180"
        Height="760"
        MinWidth="980"
        MinHeight="620"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="150"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="Quick Remote Toolkit"
                       FontSize="22"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       Margin="0,0,18,0"/>

            <TextBox Grid.Column="1"
                     x:Name="SearchBox"
                     VerticalAlignment="Center"
                     TextChanged="SearchBox_TextChanged"
                     ToolTip="Поиск по имени компьютера, IP или сотруднику"/>

            <Button Grid.Column="2"
                    Content="Открыть CSV"
                    Margin="12,0,8,0"
                    Click="ChooseCsv_Click"/>

            <Button Grid.Column="3"
                    Content="Обновить"
                    Margin="0"
                    Click="ReloadClients_Click"/>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="230"/>
            </Grid.ColumnDefinitions>

            <DataGrid x:Name="ClientsGrid"
                      Grid.Column="0"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      SelectionChanged="ClientsGrid_SelectionChanged"
                      MouseDoubleClick="ClientsGrid_MouseDoubleClick">
                <DataGrid.RowStyle>
                    <Style TargetType="{x:Type DataGridRow}">
                        <Setter Property="Background" Value="White"/>
                        <Setter Property="Foreground" Value="#202020"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Status}" Value="Checking">
                                <Setter Property="Background" Value="#FFF4D6"/>
                                <Setter Property="Foreground" Value="#664D03"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Status}" Value="Online">
                                <Setter Property="Background" Value="#EAF7EA"/>
                                <Setter Property="Foreground" Value="#0F5132"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Status}" Value="Offline">
                                <Setter Property="Background" Value="#FDECEC"/>
                                <Setter Property="Foreground" Value="#842029"/>
                            </DataTrigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#2D6CDF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="№" Binding="{Binding Number}" Width="55"/>
                    <DataGridTextColumn Header="Компьютер" Binding="{Binding Computer}" Width="180"/>
                    <DataGridTextColumn Header="IP" Binding="{Binding Ip}" Width="140"/>
                    <DataGridTextColumn Header="Сотрудник" Binding="{Binding Person}" Width="*"/>
                    <DataGridTextColumn Header="Статус" Binding="{Binding StatusText}" Width="120"/>
                    <DataGridTextColumn Header="Последняя проверка" Binding="{Binding LastCheckedText}" Width="150"/>
                </DataGrid.Columns>
            </DataGrid>

            <ScrollViewer Grid.Column="1" Margin="12,0,0,0" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Действия"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Margin="0,0,0,10"/>

                    <Button Content="Remote Assistance" Click="RemoteAssistance_Click"/>
                    <Button Content="Ping" Click="PingSelected_Click"/>
                    <Button Content="Tracert" Click="Tracert_Click"/>
                    <Button Content="Открыть C$" Click="AdminShare_Click"/>
                    <Button Content="Event Viewer" Click="EventViewer_Click"/>
                    <Button Content="Computer Management" Click="ComputerManagement_Click"/>
                    <Button Content="MSTSC" Click="Mstsc_Click"/>
                    <Button Content="WinRS cmd" Click="WinRsCmd_Click"/>
                    <Button Content="gpupdate /force" Click="Gpupdate_Click"/>
                    <Button Content="Копировать имя ПК" Click="CopyComputer_Click"/>
                    <Button Content="Копировать IP" Click="CopyIp_Click"/>

                    <Separator Margin="0,6,0,12"/>
                    <Button Content="Проверить всех" Click="PingAll_Click"/>
                    <Button Content="Экспорт логов" Click="ExportLogs_Click"/>

                    <TextBlock Text="CSV"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Margin="0,14,0,4"/>
                    <TextBlock x:Name="CsvPathText"
                               TextWrapping="Wrap"
                               Foreground="#555"/>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <GridSplitter Grid.Row="2"
                      Height="8"
                      Margin="0,8,0,0"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Center"
                      Background="Transparent"
                      Cursor="SizeNS"
                      ResizeBehavior="PreviousAndNext"
                      ResizeDirection="Rows"
                      ShowsPreview="True"
                      ToolTip="Изменить размер журнала"/>

        <GroupBox Grid.Row="3" Header="Журнал" Margin="0,4,0,0">
            <DataGrid x:Name="LogGrid"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Время" Binding="{Binding TimeText}" Width="135"/>
                    <DataGridTextColumn Header="Компьютер" Binding="{Binding Computer}" Width="160"/>
                    <DataGridTextColumn Header="Действие" Binding="{Binding Action}" Width="210"/>
                    <DataGridTextColumn Header="Результат" Binding="{Binding Result}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>
    </Grid>
</Window>
