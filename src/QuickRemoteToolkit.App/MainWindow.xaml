<Window x:Class="QuickRemoteToolkit.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quick Remote Toolkit"
        Width="1500"
        Height="920"
        MinWidth="1200"
        MinHeight="760"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBackgroundBrush}">
    <Window.InputBindings>
        <KeyBinding Key="F" Modifiers="Control" Command="{Binding FocusSearchCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
    </Window.InputBindings>
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="190"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,24,0">
                <Border Width="42"
                        Height="42"
                        Background="{StaticResource AccentBrush}"
                        CornerRadius="10"
                        Margin="0,0,12,0">
                    <TextBlock Text="&#xE977;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="23"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="Quick Remote Toolkit"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <Grid Grid.Column="1" MaxWidth="660" HorizontalAlignment="Stretch" VerticalAlignment="Center">
                <TextBox x:Name="SearchBox"
                         TextChanged="SearchBox_TextChanged"
                         ToolTip="Поиск по имени компьютера, IP или сотруднику"/>
                <TextBlock Text="Поиск компьютера, сотрудника или IP..."
                           Foreground="{StaticResource TextMutedBrush}"
                           Margin="14,0,0,0"
                           VerticalAlignment="Center"
                           IsHitTestVisible="False">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <Border HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="0,0,10,0"
                        Background="{StaticResource CardMutedBrush}"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="7,2">
                    <TextBlock Text="Ctrl+F"
                               FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                </Border>
            </Grid>

            <Button Grid.Column="2"
                    Margin="12,0,8,0"
                    Click="ChooseCsv_Click"
                    ToolTip="Выбрать CSV-файл со списком клиентов">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE8E5;" Style="{StaticResource IconTextStyle}"/>
                    <TextBlock Text="Открыть CSV"/>
                </StackPanel>
            </Button>

            <Button Grid.Column="3"
                    Margin="0"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Click="ReloadClients_Click"
                    ToolTip="Перечитать список клиентов из выбранного CSV">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE72C;" Style="{StaticResource IconTextStyle}" Foreground="White"/>
                    <TextBlock Text="Обновить"/>
                </StackPanel>
            </Button>
        </Grid>

        <Border Grid.Row="1"
                Grid.Column="0"
                Style="{StaticResource CardStyle}"
                Padding="10"
                Margin="0,0,12,0">
            <Border Background="White"
                    BorderBrush="{StaticResource DividerBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="1">
                <DataGrid x:Name="ClientsGrid"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          AlternationCount="2"
                          SelectionMode="Single"
                          SelectionChanged="ClientsGrid_SelectionChanged"
                          MouseDoubleClick="ClientsGrid_MouseDoubleClick"
                          PreviewMouseRightButtonDown="ClientsGrid_PreviewMouseRightButtonDown">
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Remote Assistance" Click="RemoteAssistance_Click"/>
                            <MenuItem Header="Ping" Click="PingSelected_Click"/>
                            <MenuItem Header="Tracert" Click="Tracert_Click"/>
                            <Separator/>
                            <MenuItem Header="Открыть C$" Click="AdminShare_Click"/>
                            <MenuItem Header="Event Viewer" Click="EventViewer_Click"/>
                            <MenuItem Header="Computer Management" Click="ComputerManagement_Click"/>
                            <MenuItem Header="MSTSC" Click="Mstsc_Click"/>
                            <MenuItem Header="WinRS cmd" Click="WinRsCmd_Click"/>
                            <MenuItem Header="gpupdate /force" Click="Gpupdate_Click"/>
                            <Separator/>
                            <MenuItem Header="Копировать имя ПК" Click="CopyComputer_Click"/>
                            <MenuItem Header="Копировать IP" Click="CopyIp_Click"/>
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                    <DataGrid.RowStyle>
                        <Style TargetType="{x:Type DataGridRow}">
                            <Setter Property="Background" Value="White"/>
                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                            <Style.Triggers>
                                <Trigger Property="AlternationIndex" Value="1">
                                    <Setter Property="Background" Value="#FBFCFE"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{StaticResource SelectedRowBrush}"/>
                                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="№" Binding="{Binding Number}" SortMemberPath="Number" Width="58" ElementStyle="{StaticResource GridTextStyle}"/>
                        <DataGridTextColumn Header="Компьютер" Binding="{Binding Computer}" SortMemberPath="Computer" Width="190" ElementStyle="{StaticResource GridTextStyle}"/>
                        <DataGridTextColumn Header="IP" Binding="{Binding Ip}" SortMemberPath="Ip" Width="150" ElementStyle="{StaticResource GridTextStyle}"/>
                        <DataGridTextColumn Header="Сотрудник" Binding="{Binding Person}" SortMemberPath="Person" Width="*" ElementStyle="{StaticResource GridTextStyle}"/>
                        <DataGridTemplateColumn Header="Статус" SortMemberPath="StatusText" Width="150">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0">
                                        <Ellipse Width="9"
                                                 Height="9"
                                                 Fill="{Binding StatusBrush}"
                                                 Margin="0,0,9,0"/>
                                        <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Последняя проверка" Binding="{Binding LastCheckedText}" SortMemberPath="LastChecked" Width="170" ElementStyle="{StaticResource GridTextStyle}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Border>

        <ScrollViewer Grid.Row="1"
                      Grid.RowSpan="3"
                      Grid.Column="1"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="&#xE8AF;" Style="{StaticResource SectionHeaderIconStyle}"/>
                            <TextBlock Text="Подключение"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <Button Style="{StaticResource ToolButtonStyle}" Click="RemoteAssistance_Click" ToolTip="Открыть Windows Remote Assistance для выбранного клиента">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8AF;" Style="{StaticResource IconTextStyle}" Foreground="{StaticResource AccentBrush}"/>
                                <TextBlock Text="Remote Assistance"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource ToolButtonStyle}" Click="PingSelected_Click" ToolTip="Проверить доступность выбранного клиента">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE701;" Style="{StaticResource IconTextStyle}" Foreground="{StaticResource AccentBrush}"/>
                                <TextBlock Text="Ping"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource ToolButtonStyle}" Click="Tracert_Click" ToolTip="Открыть трассировку маршрута до выбранного клиента">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE774;" Style="{StaticResource IconTextStyle}" Foreground="{StaticResource AccentBrush}"/>
                                <TextBlock Text="Tracert"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource ToolButtonStyle}" Click="AdminShare_Click" ToolTip="Открыть административную шару C$ выбранного клиента">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8B7;" Style="{StaticResource IconTextStyle}" Foreground="{StaticResource AccentBrush}"/>
                                <TextBlock Text="Открыть C$"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="&#xE713;" Style="{StaticResource SectionHeaderIconStyle}"/>
                            <TextBlock Text="Инструменты"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <Button Style="{StaticResource ToolButtonStyle}" Click="EventViewer_Click" ToolTip="Открыть просмотр событий выбранного удаленного ПК">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8A5;" Style="{StaticResource IconTextStyle}" Foreground="{StaticResource AccentBrush}"/>
                                <TextBlock Text="Event Viewer"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource ToolButtonStyle}" Click="ComputerManagement_Click" ToolTip="Открыть управление компьютером для выбранного клиента">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE977;" Style="{StaticResource IconTextStyle}" Foreground="{StaticResource AccentBrush}"/>
                                <TextBlock Text="Computer Management"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource ToolButtonStyle}" Click="Mstsc_Click" ToolTip="Запустить подключение через Remote Desktop">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE7F4;" Style="{StaticResource IconTextStyle}" Foreground="{StaticResource AccentBrush}"/>
                                <TextBlock Text="MSTSC"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource ToolButtonStyle}" Click="WinRsCmd_Click" ToolTip="Открыть удаленную командную строку через WinRS">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE756;" Style="{StaticResource IconTextStyle}" Foreground="{StaticResource AccentBrush}"/>
                                <TextBlock Text="WinRS cmd"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource ToolButtonStyle}" Click="Gpupdate_Click" ToolTip="Запустить обновление групповых политик на выбранном клиенте">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE713;" Style="{StaticResource IconTextStyle}" Foreground="{StaticResource AccentBrush}"/>
                                <TextBlock Text="gpupdate /force"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="&#xE9D2;" Style="{StaticResource SectionHeaderIconStyle}"/>
                            <TextBlock Text="Операции"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <Button Style="{StaticResource ToolButtonStyle}" Click="PingAll_Click" ToolTip="Параллельно проверить ping для всех клиентов из списка">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE716;" Style="{StaticResource IconTextStyle}" Foreground="{StaticResource AccentBrush}"/>
                                <TextBlock Text="Проверить всех"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource ToolButtonStyle}" Click="ExportLogs_Click" ToolTip="Сохранить журнал действий в TXT или CSV">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE74E;" Style="{StaticResource IconTextStyle}" Foreground="{StaticResource AccentBrush}"/>
                                <TextBlock Text="Экспорт логов"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="&#xE77B;" Style="{StaticResource SectionHeaderIconStyle}"/>
                            <TextBlock Text="Админ-доступ"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="Пользователь"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,0,6"/>
                        <TextBox x:Name="AdminUserBox"
                                 ToolTip="Доменный пользователь для подготовки SMB-сессии, например GTL\kmn"/>
                        <Button Style="{StaticResource ToolButtonStyle}"
                                Click="SaveAdminUser_Click"
                                ToolTip="Сохранить пользователя для подключения к административным шарам">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE74E;" Style="{StaticResource IconTextStyle}" Foreground="{StaticResource AccentBrush}"/>
                                <TextBlock Text="Сохранить"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="&#xE8E5;" Style="{StaticResource SectionHeaderIconStyle}"/>
                            <TextBlock Text="CSV"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <Border Background="{StaticResource CardMutedBrush}"
                                BorderBrush="{StaticResource DividerBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12">
                            <TextBlock x:Name="CsvPathText"
                                       TextWrapping="Wrap"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </Border>
                        <TextBlock x:Name="CsvInfoText"
                                   Margin="0,12,0,0"
                                   Foreground="{StaticResource TextMutedBrush}"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <GridSplitter Grid.Row="2"
                      Grid.Column="0"
                      Height="10"
                      Margin="0,6,12,6"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Center"
                      Background="Transparent"
                      Cursor="SizeNS"
                      ResizeBehavior="PreviousAndNext"
                      ResizeDirection="Rows"
                      ShowsPreview="True"
                      ToolTip="Изменить размер журнала"/>

        <Border Grid.Row="3"
                Grid.Column="0"
                Style="{StaticResource CardStyle}"
                Padding="10"
                Margin="0,0,12,0">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top"
                            Orientation="Horizontal"
                            Margin="4,2,4,10">
                    <TextBlock Text="&#xE8FD;"
                               Style="{StaticResource IconTextStyle}"
                               Foreground="{StaticResource AccentBrush}"/>
                    <TextBlock Text="Журнал"
                               FontSize="14"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <Border Background="White"
                        BorderBrush="{StaticResource DividerBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="1">
                    <DataGrid x:Name="LogGrid"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Время" Binding="{Binding TimeText}" SortMemberPath="Time" Width="155" ElementStyle="{StaticResource GridTextStyle}"/>
                            <DataGridTextColumn Header="Компьютер" Binding="{Binding Computer}" SortMemberPath="Computer" Width="180" ElementStyle="{StaticResource GridTextStyle}"/>
                            <DataGridTextColumn Header="Действие" Binding="{Binding Action}" SortMemberPath="Action" Width="230" ElementStyle="{StaticResource GridTextStyle}"/>
                            <DataGridTextColumn Header="Результат" Binding="{Binding Result}" SortMemberPath="Result" Width="*" ElementStyle="{StaticResource GridTextStyle}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </DockPanel>
        </Border>
    </Grid>
</Window>
